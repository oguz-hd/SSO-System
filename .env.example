# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=admin_db

# MySQL (raporlama arşivi)
MYSQL_ROOT_PASSWORD=root123
MYSQL_USER=admin
MYSQL_PASSWORD=admin123
MYSQL_DB=admin_reports

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
DATABASE_URL=postgresql+asyncpg://admin:admin123@postgres:5432/admin_db
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
API_PORT=8000
MAX_UPLOAD_MB=10
# OpenAI — gerçek LLM için zorunlu (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-BURAYA_ANAHTARINIZI_YAZIN
OPENAI_MODEL=gpt-4o-mini
# Azure / uyumlu proxy kullanıyorsanız:
# OPENAI_BASE_URL=https://api.openai.com/v1

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
